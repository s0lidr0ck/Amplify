{
  "name": "amplify",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/api-client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "lint": "npm run lint --workspace=web",
    "generate:api-client": "openapi-typescript http://localhost:8000/openapi.json -o packages/api-client/src/client.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0"
}
