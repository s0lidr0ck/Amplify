# App
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
# If port 8000 is stuck: API_URL=http://localhost:8001 and NEXT_PUBLIC_API_URL=http://localhost:8001
# Accepts either a single origin or a comma/newline/JSON array of origins.
# `CORS_ORIGIN` is supported for backward compatibility; `CORS_ORIGINS` is preferred.
CORS_ORIGINS=http://localhost:3000

# Database
# Local (Docker): postgresql+asyncpg://amplify:amplify@localhost:5432/amplify
# Cloud (Neon/Supabase): postgresql+asyncpg://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql+asyncpg://amplify:amplify@localhost:5432/amplify

# Redis (optional for local dev; API doesn't use it yet)
REDIS_URL=redis://localhost:6379/0

# Object storage (S3-compatible, MinIO for local)
S3_BUCKET=amplify
S3_REGION=us-east-1
S3_ACCESS_KEY=amplify
S3_SECRET_KEY=amplify123
S3_ENDPOINT=http://localhost:9000

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# AI (for content generation, clip analysis)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Error tracking
SENTRY_DSN=

# Dev: create placeholder transcript immediately (no worker needed)
SYNC_TRANSCRIPT_DEV=false

# Dev: create placeholder sermon master immediately (no worker needed)
SYNC_TRIM_DEV=false

# Worker: API base URL for internal calls (default matches API on 8000)
API_URL=http://localhost:8000
